# OpenAI
OPENAI_API_KEY=sk-...

# Embeddings (RAG / Chroma)
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# OpenAI — чат-модель для ассистента
OPENAI_CHAT_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2

# RAG retrieval
RAG_TOP_K=4
RAG_FETCH_K=12
RAG_MAX_DISTANCE=1.25
RAG_FOLDER_BOOST=0.12
RAG_CONTENT_BOOST=0.15
ENABLE_QUALITY_CHECK=true

# Telegram Bot (от @BotFather) — для будущего бота
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Пути проекта
SOURCE_DIR=./source
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=inmyheart_kb

# Локальные эмбеддинги (если EMBEDDING_PROVIDER=huggingface)
# HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
