# OpenAI
OPENAI_API_KEY=sk-...

# Embeddings (RAG / Chroma)
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# OpenAI — чат-модель для ассистента
OPENAI_CHAT_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.2

# RAG retrieval
RAG_TOP_K=4
RAG_FETCH_K=12
RAG_MAX_DISTANCE=1.25
RAG_FOLDER_BOOST=0.12
RAG_CONTENT_BOOST=0.15
ENABLE_QUALITY_CHECK=true

# Telegram Bot (от @BotFather)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Группа операторов (chat id супергруппы, отрицательное число)
# TELEGRAM_OPERATOR_CHAT_ID=-1001234567890

# notify — уведомление | relay — задел прокси-чат (см. operator_handoff.md)
TELEGRAM_HANDOFF_MODE=notify

# Forum Topics: отдельная ветка на каждого клиента в группе операторов
TELEGRAM_USE_FORUM_TOPICS=true
TELEGRAM_FORWARD_CLIENT_MESSAGES=true
# true — после /reset создаётся новый топик при следующей эскалации
TELEGRAM_NEW_TOPIC_AFTER_RESET=false

# SQLite: логи диалогов, эскалации, KPI
# DIALOG_DB_PATH=./data/inmyheart.db
TELEGRAM_OPERATOR_SESSION_TIMEOUT_SEC=600
KPI_RESPONSE_SLA_MS=5000

# FastAPI
API_HOST=127.0.0.1
API_PORT=8000

# Пути проекта
SOURCE_DIR=./source
CHROMA_PERSIST_DIR=./data/chroma
CHROMA_COLLECTION=inmyheart_kb

# Локальные эмбеддинги (если EMBEDDING_PROVIDER=huggingface)
# HUGGINGFACE_EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
